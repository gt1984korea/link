[debug] [2026-06-14T03:16:50.740Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/victorychurch-665a9/rulesets {"name":"projects/victorychurch-665a9/rulesets/e5e30af8-3486-49e5-91ba-14a162baa1ff","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // 사이트 공용 콘텐츠: 누구나 읽기 가능, 쓰기는 금지(아래 주석 참고)\n    match /site/{docId} {\n      allow read: if true;\n\n      // ⚠️ 기본은 클라이언트 쓰기 차단입니다.\n      // admin.html 의 비밀번호 게이트는 화면 보호용일 뿐 보안이 아닙니다.\n      // 진짜 쓰기 보안은 다음 중 한 가지 방식을 선택해 적용하세요:\n      //\n      // 1) 가장 간단 — 일시적으로 열어두기 (소규모 / 신뢰된 관리자만):\n      //    allow write: if true;\n      //\n      // 2) Firebase Authentication 사용 (권장):\n      //    - Firebase Console > Authentication 활성화 후 관리자 계정 생성\n      //    - admin.html 에 signInWithEmailAndPassword 추가\n      //    - 아래 규칙으로 교체:\n      //    allow write: if request.auth != null\n      //                 && request.auth.token.email in ['admin@victorychurch.nz'];\n      //\n      // 3) 커스텀 클레임 사용 (다수 관리자):\n      //    allow write: if request.auth != null && request.auth.token.admin == true;\n\n      allow write: if true;\n    }\n\n    // 웹 푸시 토큰 저장소: 클라이언트는 자기 토큰만 등록(create/update) 가능.\n    // 목록 읽기/삭제는 차단 — 발송과 정리는 Cloud Function(Admin SDK)이 규칙을 우회해 처리합니다.\n    match /pushTokens/{token} {\n      allow get: if true;\n      allow create, update: if true;\n      allow list, delete: if false;\n    }\n\n    // 그 외 모든 경로는 차단\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-14T03:16:44.496447Z","metadata":{"services":["cloud.firestore"]}}
