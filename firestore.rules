rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사이트 공용 콘텐츠: 누구나 읽기 가능, 쓰기는 금지(아래 주석 참고)
    match /site/{docId} {
      allow read: if true;

      // ⚠️ 기본은 클라이언트 쓰기 차단입니다.
      // admin.html 의 비밀번호 게이트는 화면 보호용일 뿐 보안이 아닙니다.
      // 진짜 쓰기 보안은 다음 중 한 가지 방식을 선택해 적용하세요:
      //
      // 1) 가장 간단 — 일시적으로 열어두기 (소규모 / 신뢰된 관리자만):
      //    allow write: if true;
      //
      // 2) Firebase Authentication 사용 (권장):
      //    - Firebase Console > Authentication 활성화 후 관리자 계정 생성
      //    - admin.html 에 signInWithEmailAndPassword 추가
      //    - 아래 규칙으로 교체:
      //    allow write: if request.auth != null
      //                 && request.auth.token.email in ['admin@victorychurch.nz'];
      //
      // 3) 커스텀 클레임 사용 (다수 관리자):
      //    allow write: if request.auth != null && request.auth.token.admin == true;

      allow write: if request.auth != null && request.auth.token.email == 'admin@victorychurch.nz';
    }

    // 구절 좋아요 카운터: /verseStats/{verseId} = { likes }
    // 방문자가 increment(±1)로 좋아요 수를 증감. 기존 /site 정책과 동일한 개방형 규칙.
    // ⚠️ 누구나 호출 가능(조작 가능) — 소규모/신뢰 환경 전제. 강화 시 App Check 사용.
    match /verseStats/{verseId} {
      allow read: if true;
      allow write: if true;
    }

    // 웹 푸시 토큰 저장소: 클라이언트는 자기 토큰만 등록(create/update) 가능.
    // 목록 읽기/삭제는 차단 — 발송과 정리는 Cloud Function(Admin SDK)이 규칙을 우회해 처리합니다.
    match /pushTokens/{token} {
      allow get: if true;
      allow create, update: if true;
      allow list, delete: if false;
    }

    // 중보기도: /prayers/{id} = { id, name, title, content, visibility, prayCount, status, createdAt }
    //  - title(기도 제목)은 공개/비공개 모두 게시판에 노출됩니다.
    //  - content(내용)은 공개 글만 여기에 담깁니다. 비공개 글은 content=='' 이고 실제 내용은 /prayerContents 에 저장.
    // 방문자가 기도제목을 작성(create)하고, 다른 방문자는 '함께 기도' 카운터(prayCount)만 +1 올릴 수 있습니다.
    // 제목/내용/이름/공개여부 등 기존 필드는 방문자가 수정할 수 없습니다(update는 prayCount +1만 허용).
    match /prayers/{id} {
      allow read: if true;
      allow create: if isValidNewPrayer();
      // 방문자: prayCount +1만. 관리자(암호 게이트): status를 active<->hidden 토글해 게시판에서 숨김/복원.
      allow update: if isPrayCountBump() || isStatusToggle();
      // 삭제는 관리자 검열용(암호 게이트). verseStats와 동일하게 조작 가능 — 소규모/신뢰 환경 전제.
      allow delete: if true;
    }

    // 비공개 기도 "내용": /prayerContents/{id} = { text }
    // 게시판(prayer.html)은 이 컬렉션을 읽지 않습니다 → 비공개 내용이 방문자에게 전송되지 않음.
    // ⚠️ read가 열려 있어 API로 직접 조회하면 읽힐 수 있는 "관례적 비공개"입니다(신뢰 환경 전제).
    //    완전한 비공개는 관리자 Firebase Auth + read 규칙 강화가 필요합니다(PRAYER_SETUP.md 참고).
    match /prayerContents/{id} {
      allow read: if true;
      allow create: if isValidPrayerContent();
      allow update: if false;
      allow delete: if true;
    }

    function isValidNewPrayer() {
      let d = request.resource.data;
      return d.keys().hasOnly(['id', 'name', 'title', 'content', 'visibility', 'prayCount', 'status', 'createdAt'])
        && d.title is string && d.title.size() >= 1 && d.title.size() <= 100
        && d.content is string && d.content.size() <= 1000
        && d.name is string && d.name.size() <= 40
        && d.visibility in ['public', 'private']
        && (d.visibility == 'public' || d.content == '')   // 비공개 글은 내용을 여기 담지 않음
        && d.status == 'active'
        && d.prayCount == 0
        && d.createdAt == request.time;
    }

    function isValidPrayerContent() {
      let d = request.resource.data;
      return d.keys().hasOnly(['text'])
        && d.text is string && d.text.size() >= 1 && d.text.size() <= 1000;
    }

    function isPrayCountBump() {
      let d = request.resource.data;
      return d.diff(resource.data).affectedKeys().hasOnly(['prayCount'])
        && d.prayCount == resource.data.prayCount + 1;
    }

    // 관리자 숨김/복원: status 필드만 active<->hidden 로 변경 (검열용, 삭제보다 덜 파괴적)
    function isStatusToggle() {
      let d = request.resource.data;
      return d.diff(resource.data).affectedKeys().hasOnly(['status'])
        && d.status in ['active', 'hidden'];
    }

    // 그 외 모든 경로는 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
